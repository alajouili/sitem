# ============================================================
# SECRETS — never commit real credentials, ever.
# .env.example files ARE committed (they're templates, no
# secrets) — only the real .env files are excluded here.
# ============================================================
.env
backend/.env
frontend/.env

# ============================================================
# Dependencies — regenerated from lockfiles, never committed.
# composer.lock and package-lock.json themselves ARE committed
# (that's what makes builds reproducible) — only the installed
# packages/output are excluded.
# ============================================================
backend/vendor/
frontend/node_modules/

# ============================================================
# Build output — regenerated by `npm run build` / CI, never
# hand-edited, no reason to version it.
# ============================================================
frontend/dist/

# ============================================================
# Runtime data — user uploads and logs are STATE, not CODE.
# Same principle as backend/.dockerignore: these live in the
# Docker volume (backend-storage) at runtime, never in the repo.
# ============================================================
backend/storage/uploads/*
backend/storage/logs/*
!backend/storage/uploads/.gitkeep
!backend/storage/logs/.gitkeep

# ============================================================
# Editor / OS noise
# ============================================================
.vscode/
.idea/
.DS_Store
Thumbs.db

# ============================================================
# Local debugging artifacts from this session
# ============================================================
compose_output.txt